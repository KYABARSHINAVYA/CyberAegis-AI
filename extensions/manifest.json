{
  "manifest_version": 3,
  "name": "CyberAegis AI",
  "description": "Browser extension for URL, email, QR, sandbox, Telegram alert, and global phishing threat map workflows.",
  "version": "1.1.0",
  "permissions": [
    "activeTab",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://cyberaegis-ai-y3dw.onrender.com/*",
    "https://t.me/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CyberAegis AI"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.svg"
  }
}
