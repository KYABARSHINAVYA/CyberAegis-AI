PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/aegisshield
GEMINI_API_KEY=your_gemini_api_key
JWT_SECRET=replace_with_a_long_random_secret

# SMTP email delivery for signup and password reset OTPs.
# For Gmail, use an app password instead of your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FAMILY=4
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
# Set to false only for local networks/proxies that inject a self-signed TLS certificate.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Set to false only if MongoDB login fails with a self-signed certificate error.
MONGO_TLS_REJECT_UNAUTHORIZED=true

# Telegram Bot API alert delivery.
# Configure these values to let the backend send alerts through Telegram.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
VERIFY_TOKEN=aegisshield_verify_2026
