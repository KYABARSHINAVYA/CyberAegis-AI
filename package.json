{
  "name": "aegis-shield-workspace",
  "version": "1.0.0",
  "description": "Integrated Workspace for AegisShield AI Phishing and Deepfake Defense",
  "private": true,
  "scripts": {
    "install-backend": "npm install --prefix backend",
    "install-frontend": "npm install --prefix frontend",
    "install-all": "npm run install-backend && npm run install-frontend",
    "dev-backend": "npm run dev --prefix backend",
    "dev-frontend": "npm run dev --prefix frontend",
    "start-backend": "npm run start --prefix backend",
    "dev": "concurrently --kill-others \"npm run dev-backend\" \"npm run dev-frontend\"",
    "start": "concurrently --kill-others \"npm run start-backend\" \"npm run dev-frontend\""
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.2",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "framer-motion": "^12.40.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1"
  }
}
